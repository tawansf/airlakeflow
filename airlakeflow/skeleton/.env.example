# Copy this file to .env and fill in the values.

# Docker Compose / healthchecks (optional; container sets HOSTNAME if unset)
HOSTNAME=airflow

# Airflow (container user UID). Linux/macOS: alf run sets this to your user. Windows: use 50000 if you get permission errors on logs.
AIRFLOW_UID=1000

# Postgres host port (change if 5432 is in use by another project or local DB)
POSTGRES_HOST_PORT=5432

# Data warehouse
DATAWAREHOUSE_DB=datawarehouse

# Soda Core
SODA_PATH=/opt/airflow/soda
