# Copy this file to .env and fill in the values.
# Variables required for the crypto pipeline:

# Airflow (UID do usuário no container)
AIRFLOW_UID=1000

# API CoinGecko (bronze ingestion)
GEEKO_URL_API=https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd&include_last_updated_at=true

# Data warehouse (database name; used in JDBC URL and Soda)
DATAWAREHOUSE_DB=datawarehouse

# Spark / JDBC (PostgreSQL driver)
JAR_PATH=/opt/airflow/plugins/postgresql-42.2.18.jar
DRIVER_CLASS=org.postgresql.Driver

# Soda Core (checks and configuration path)
SODA_PATH=/opt/airflow/soda

# Optional: Postgres credentials for Soda (if different from airflow/airflow)
# Change soda/configuration.yaml or use secrets in production.
# SODA_POSTGRES_PASSWORD=
