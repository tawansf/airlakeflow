    hook = PostgresHook(postgres_conn_id="postgres_datawarehouse")
    uri = hook.get_uri()
    if uri.startswith("postgresql://"):
        uri = "postgresql+psycopg2://" + uri[len("postgresql://"):]
    engine = create_engine(uri)
    try:
{% if incremental_by %}
        df = pd.read_sql(
            'SELECT * FROM bronze."{{ entity_snake }}_raw" WHERE "{{ incremental_by }}" > %(last_max)s',
            engine,
            params={"last_max": last_max},
        )
{% else %}
        df = pd.read_sql('SELECT * FROM bronze."{{ entity_snake }}_raw"', engine)
{% endif %}
        if df.empty:
