"""Run ALF-Checks from config/checks/. Generated by 'alf add alf-checks'."""
from pathlib import Path

from airflow import DAG
from airflow.operators.python import PythonOperator
from airflow.exceptions import AirflowException
from datetime import datetime

from airlakeflow.data_tests import run_data_tests


def _run_alf_checks(**context):
    dag_file = Path(__file__).resolve()
    project_root = dag_file.parent.parent
    code = run_data_tests(project_root)
    if code != 0:
        raise AirflowException("ALF-Checks failed (see logs).")


with DAG(
    dag_id="01_alf_checks",
    start_date=datetime(2026, 1, 1),
    schedule_interval=None,
    catchup=False,
    tags=["quality", "alf_checks"],
) as dag:
    PythonOperator(
        task_id="run_alf_checks",
        python_callable=_run_alf_checks,
    )
