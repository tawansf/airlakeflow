"""Run data tests from config/data_tests.yaml. Generated by 'alf data-tests'."""
from pathlib import Path

from airflow import DAG
from airflow.operators.python import PythonOperator
from airflow.exceptions import AirflowException
from datetime import datetime

from airlakeflow.data_tests import run_data_tests


def _run_data_tests(**context):
    dag_file = Path(__file__).resolve()
    project_root = dag_file.parent.parent
    code = run_data_tests(project_root)
    if code != 0:
        raise AirflowException("Data tests failed (see logs).")


with DAG(
    dag_id="01_data_tests",
    start_date=datetime(2026, 1, 1),
    schedule_interval=None,
    catchup=False,
    tags=["quality", "data_tests"],
) as dag:
    PythonOperator(
        task_id="run_data_tests",
        python_callable=_run_data_tests,
    )
