# Data Contract - Silver {{ table_name }}
dataset: spark_df/__TABLE__

checks:
  - row_count:
      name: "Table row count must be greater than 0"
      threshold:
        must_be_greater_than: 0
  - schema:
      name: "Table schema must be valid"
      allow_extra_columns: false
      allow_other_column_order: false
  - freshness:
      name: "Data must be recent (less than 48 hours old)"
      column: updated_at
      threshold:
        unit: hour
        must_be_less_than: 48

columns:
  - name: id
    checks:
      - duplicate:
          name: No duplicate IDs
  - name: entity_id
    checks:
      - missing:
          name: Entity ID never null
          threshold:
            must_be: 0
  - name: value
    checks:
      - aggregate:
          name: Value is not negative
          function: min
          threshold:
            must_be_greater_than_or_equal: 0
